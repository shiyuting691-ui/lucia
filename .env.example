# ─────────────────────────────────────────
# 极致教育增长作战系统 · 环境变量模板
# 使用方法：cp .env.example .env，然后填写真实值
# 注意：.env 文件绝对不能提交到 GitHub
# ─────────────────────────────────────────

# Anthropic AI（必填）
ANTHROPIC_API_KEY=

# 企业微信 Webhook（必填，用于推送周报/月报/每日提醒）
WECHAT_WORK_WEBHOOK=

# OpenAI（可选，海报生成备用）
OPENAI_API_KEY=

# Dify（可选，知识库接入）
DIFY_API_KEY=
DIFY_BASE_URL=

# Langfuse（可选，AI 调用追踪）
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=

# 应用环境
APP_ENV=production

# 数据库（默认 SQLite，可改为 PostgreSQL）
DATABASE_URL=sqlite:///data/marketing.db

# Streamlit
STREAMLIT_SERVER_PORT=8501
STREAMLIT_SERVER_ADDRESS=0.0.0.0

# Cloudflare R2 对象存储（可选，留空则文件存本地磁盘）
# 四项全部填写后 services/object_storage.py 自动切换到 R2
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
